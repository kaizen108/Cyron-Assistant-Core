# Install nginx on the VPS, then:
#   sudo cp deploy/nginx.conf.example /etc/nginx/sites-available/api.cyronticket.com
#   sudo ln -s /etc/nginx/sites-available/api.cyronticket.com /etc/nginx/sites-enabled/
#   sudo certbot --nginx -d api.cyronticket.com
#   sudo nginx -t && sudo systemctl reload nginx

server {
    listen 80;
    server_name api.cyronticket.com;

    location / {
        proxy_pass http://127.0.0.1:8000;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }
}
