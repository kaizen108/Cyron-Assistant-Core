# Discord bot
DISCORD_TOKEN=your_discord_bot_token
DISCORD_CLIENT_ID=your_discord_application_client_id
DISCORD_CLIENT_SECRET=your_discord_application_client_secret

# Internal bot ↔ backend auth (generate a long random string)
BOT_API_KEY=generate_a_long_random_hex_string

# JWT signing for dashboard sessions
AUTH_JWT_SECRET=generate_a_long_random_hex_string

# AI provider (LiteLLM — use OPENAI_API_KEY with gemini/ model prefix, or set OPENAI_MODEL explicitly)
OPENAI_API_KEY=your_ai_provider_api_key
GEMINI_MODEL=gemini/gemini-2.0-flash-lite
# OPENAI_MODEL=gemini/gemini-2.0-flash-lite

# Public URLs (production)
BACKEND_PUBLIC_URL=https://api.cyronticket.com
FRONTEND_PUBLIC_URL=https://cyron-assistant-frontend.vercel.app
FRONTEND_ALLOWED_ORIGINS=https://cyron-assistant-frontend.vercel.app,http://localhost:5173
DISCORD_OAUTH_ALLOWED_REDIRECT_URIS=https://cyron-assistant-frontend.vercel.app/auth/callback,http://localhost:5173/auth/callback

# Database & cache (Docker Compose defaults shown; override for external services)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/ai_ticket_assistant
REDIS_URL=redis://redis:6379/0
# POSTGRES_PASSWORD=postgres

# Server
HOST=0.0.0.0
PORT=8000
RELOAD=false
LOG_LEVEL=INFO
