# Discord bot (required)
DISCORD_TOKEN=your_discord_bot_token

# Discord OAuth for dashboard login (required)
DISCORD_CLIENT_ID=your_discord_application_client_id
DISCORD_CLIENT_SECRET=your_discord_client_secret

# Shared secret between bot and backend (required — generate a long random string)
BOT_API_KEY=generate_a_long_random_hex_string

# JWT signing secret for dashboard sessions (required — generate a long random string)
AUTH_JWT_SECRET=generate_a_long_random_hex_string

# AI providers (at least one recommended)
OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-4o-mini
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini/gemini-2.0-flash-lite

# Public URLs (required for production)
FRONTEND_ALLOWED_ORIGINS=https://cyron-assistant-frontend.vercel.app,http://localhost:5173
FRONTEND_PUBLIC_URL=https://cyron-assistant-frontend.vercel.app
BACKEND_PUBLIC_URL=https://api.cyronticket.com
DISCORD_OAUTH_ALLOWED_REDIRECT_URIS=https://cyron-assistant-frontend.vercel.app/auth/callback,http://localhost:5173/auth/callback

# Database & cache
# Docker Compose (services named postgres/redis):
DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/ai_ticket_assistant
REDIS_URL=redis://redis:6379/0
POSTGRES_PASSWORD=postgres

# Bot → backend URL (Docker Compose overrides this to http://api:8000 for the bot service)
BACKEND_URL=http://localhost:8000

# Server
HOST=0.0.0.0
PORT=8000
RELOAD=false
LOG_LEVEL=INFO
UVICORN_WORKERS=1
